# ==============================================================================
# ReturnGuard AI - Environment Variables Template
# config/.env.example
#
# Copy this file to ".env" at the project root and fill in real values.
# NEVER commit the real ".env" file to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# App
# ------------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true

# ------------------------------------------------------------------------------
# Database
# If DATABASE_URL is left empty, the app automatically falls back to a local
# SQLite database at database/returnguard.db (zero-config local development).
#
# Example Postgres URL:
# DATABASE_URL=postgresql://returnguard_user:CHANGE_ME@localhost:5432/returnguard_db
# ------------------------------------------------------------------------------
DATABASE_URL=

# ------------------------------------------------------------------------------
# Security / Auth
# ------------------------------------------------------------------------------
JWT_SECRET_KEY=CHANGE_ME_super_secret_random_string_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_strong_password

# ------------------------------------------------------------------------------
# API
# ------------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# ------------------------------------------------------------------------------
# Frontend (Streamlit reads this to know where the backend lives)
# ------------------------------------------------------------------------------
API_BASE_URL=http://localhost:8000/api/v1
STREAMLIT_SERVER_PORT=8501

# ------------------------------------------------------------------------------
# Deployment (Render / Docker)
# ------------------------------------------------------------------------------
PORT=8000
RENDER=false
