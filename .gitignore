# ==============================================================================
# ReturnGuard AI - .gitignore
# ==============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/

# Environment secrets
.env
.env.local

# Databases
*.db
*.sqlite
*.sqlite3
database/returnguard.db

# ML artifacts: KEPT IN GIT ON PURPOSE.
# Render's free tier has no persistent disk and no time to retrain on every
# deploy, so the pre-trained models MUST be committed and pushed to GitHub,
# or the backend will always say "train the model first" after deployment.
# (This used to exclude ml/models/*.joblib etc - that was the root cause.)
# If the repo grows too large for GitHub because of this, use Git LFS
# instead of re-adding exclusions here.
# NOTE: previously this excluded ml/data/*.csv including
# return_fraud_dataset.csv - that was WRONG. The backend re-runs
# preprocessing on that raw CSV at every startup (to rebuild the SHAP
# explainer's background sample), so it IS needed at runtime, not just
# for training. Keeping it tracked in git.

# Logs
logs/
*.log

# Jupyter
.ipynb_checkpoints/

# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Docker
docker-compose.override.yml

# Testing
.pytest_cache/
.coverage
htmlcov/
